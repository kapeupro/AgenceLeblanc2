{
  "name": "agence-leblanc",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": ["shared", "backend", "frontend"],
  "scripts": {
    "dev": "bun run --cwd backend dev & bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "build": "bun run --cwd frontend build",
    "start": "bun run --cwd backend start",
    "db:generate": "bun run --cwd backend db:generate",
    "db:migrate": "bun run --cwd backend db:migrate",
    "db:seed": "bun run --cwd backend db:seed",
    "db:import": "bun run --cwd backend db:import",
    "db:export": "bun run --cwd backend db:export"
  }
}
