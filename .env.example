# --- Base de données (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# --- Auth ---
JWT_SECRET=change-me-min-32-chars-random-string
ADMIN_EMAIL=admin@agence-leblanc.fr
ADMIN_PASSWORD=changeme

# --- Runtime ---
# `production` active le cookie `secure` (HTTPS requis côté hébergeur)
NODE_ENV=production
PORT=3001

# Optionnel : seulement si le frontend est servi sur une AUTRE origine que
# l'API. En déploiement « image unique » (recommandé) le backend sert le SPA,
# donc même origine → laissez vide / supprimez cette variable.
# FRONTEND_URL=https://www.agence-leblanc.fr
